{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Open in Chrome (file://)",
            "file": "${fileDirname}/${fileBasenameNoExtension}.html",
            "runtimeArgs": ["--allow-file-access-from-files"],
            "webRoot": "${workspaceFolder}",
            "sourceMapPathOverrides": {
                "file:///*": "${workspaceFolder}/*"
            }
        }
    ]
}